# ============================================
# OLLAMA CONFIG (Local - Cho Mac M2)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ============================================
# GROQ CONFIG (Free tier - Khuyến khích dùng)
# ============================================
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096

# ============================================
# WHISPERX CONFIG (Cho diarization)
# ============================================
WHISPER_MODEL=large-v3
DEVICE=mps                    # mps cho Mac M2, cpu cho fallback
COMPUTE_TYPE=float16          # hoặc int8 để tiết kiệm RAM
BATCH_SIZE=16

# ============================================
# BACKEND CONFIG
# ============================================
CHUNK_SIZE=5000
CHUNK_OVERLAP=1000
MAX_CONCURRENT_REQUESTS=5

# ============================================
# DATABASE CONFIG
# ============================================
DB_PATH=./data/meetings.db
CHROMA_PERSIST_DIR=./data/chroma_db

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3118,tauri://localhost

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log